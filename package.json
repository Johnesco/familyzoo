{
  "name": "familyzoo",
  "version": "1.0.0",
  "description": "Family Zoo \u2014 progressive Sharpee tutorial, v01 through v17+",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "build:all": "python C:/code/npmsharpee/tools/ship.py familyzoo local --no-test",
    "test:all": "python scripts/test-all.py",
    "ship:local": "python C:/code/npmsharpee/tools/ship.py familyzoo hub-local --no-test",
    "ship:hub": "python C:/code/npmsharpee/tools/ship.py familyzoo hub --no-test",
    "sync:banner": "python scripts/sync-sharpee-banner.py"
  },
  "dependencies": {
    "@sharpee/core": "^0.9.113",
    "@sharpee/engine": "^0.9.113",
    "@sharpee/helpers": "^0.9.113",
    "@sharpee/lang-en-us": "^0.9.113",
    "@sharpee/media": "^0.9.113",
    "@sharpee/parser-en-us": "^0.9.113",
    "@sharpee/platform-browser": "^0.9.113",
    "@sharpee/plugin-npc": "^0.9.113",
    "@sharpee/plugin-scheduler": "^0.9.113",
    "@sharpee/sharpee": "^0.9.113",
    "@sharpee/stdlib": "^0.9.113",
    "@sharpee/text-service": "^0.9.113",
    "@sharpee/world-model": "^0.9.113"
  },
  "devDependencies": {
    "@sharpee/transcript-tester": "^0.9.113",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.3"
  },
  "author": "John Googol",
  "license": "MIT"
}
